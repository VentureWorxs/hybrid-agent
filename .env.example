# Cloudflare sync endpoint (from wrangler deploy output)
SYNC_ENDPOINT_URL=https://hybrid-agent-audit-sync.<your-subdomain>.workers.dev

# Cloudflare Access service token (generated in CF Zero Trust dashboard)
CF_ACCESS_CLIENT_ID=<your-service-token-client-id>
CF_ACCESS_CLIENT_SECRET=<your-service-token-client-secret>

# Local database path (default: ~/.hybrid-agent/audit.db)
# HYBRID_AGENT_DB_PATH=/custom/path/to/audit.db

# Sync interval in seconds (default: 300)
# SYNC_INTERVAL_SECONDS=300

# Agent version (bumped on each release)
AGENT_VERSION=1.1.0
